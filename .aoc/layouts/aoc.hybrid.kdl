layout {
  tab name="__AOC_TAB_NAME__ Hybrid" focus=true {
    pane split_direction="vertical" {
      pane size="66%" split_direction="horizontal" {
        pane name="API Dev" focus=true command="bash" {
          args "-lc" "export PATH=\"$HOME/.cargo/bin:$PATH\"; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; cd \"__AOC_PROJECT_ROOT__\"; ./scripts/dev-api.sh \"${DIE_PROFILE:-lite}\" || true; exec ${AOC_TERMINAL_CMD:-$SHELL}"
        }

        pane name="UI Dev" command="bash" {
          args "-lc" "export PATH=\"$HOME/.cargo/bin:$PATH\"; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; cd \"__AOC_PROJECT_ROOT__\"; ./scripts/dev-ui.sh \"${DIE_PROFILE:-lite}\" || true; exec ${AOC_TERMINAL_CMD:-$SHELL}"
        }
      }

      pane size="34%" split_direction="horizontal" {
        pane size="58%" name="Infra Logs" command="bash" {
          args "-lc" "export PATH=\"$HOME/.cargo/bin:$PATH\"; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; cd \"__AOC_PROJECT_ROOT__\"; docker compose up -d redis ollama >/dev/null 2>&1 || true; docker compose logs -f redis ollama || true; exec ${AOC_TERMINAL_CMD:-$SHELL}"
        }

        pane size="42%" name="Dev Shell" command="bash" {
          args "-lc" "export PATH=\"$HOME/.cargo/bin:$PATH\"; export AOC_SESSION_ID=\"__AOC_SESSION_ID__\"; export AOC_HUB_ADDR=\"__AOC_HUB_ADDR__\"; export AOC_HUB_URL=\"__AOC_HUB_URL__\"; export AOC_PROJECT_ROOT=\"__AOC_PROJECT_ROOT__\"; export AOC_TAB_SCOPE=\"__AOC_TAB_NAME__\"; cd \"__AOC_PROJECT_ROOT__\"; profile=\"${DIE_PROFILE:-lite}\"; if [ -f \".env.profile.${profile}\" ]; then set -a; . \".env.profile.${profile}\"; [ -f .env ] && . .env; set +a; fi; [ -f .venv/bin/activate ] && . .venv/bin/activate; exec ${AOC_TERMINAL_CMD:-$SHELL}"
        }
      }
    }
  }
}
