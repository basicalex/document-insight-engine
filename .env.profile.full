# Document Insight runtime profile: full (opt-in)
# Keep .env for secrets only.

DIE_PROFILE=full
INSTALL_DOCLING=true
PYTHON_EXTRAS=dev,ui,ai

REQUEST_TIMEOUT_SECONDS=120
INGEST_TIMEOUT_SECONDS=1800
INGESTION_WORKER_CONCURRENCY=2
LOCAL_LLM_MODEL=hadad/LFM2.5-1.2B:Q8_0

DEEP_MODE_ENABLED=true
CLOUD_AGENT_PROVIDER=local
CLOUD_AGENT_MODEL=gemini-2.5-flash

LOCAL_EMBEDDING_PROVIDER=ollama
LOCAL_EMBEDDING_MODEL=nomic-embed-text
LOCAL_EMBEDDING_DIMENSION=768

CLOUD_EMBEDDING_PROVIDER=ollama
CLOUD_EMBEDDING_MODEL=nomic-embed-text
CLOUD_EMBEDDING_DIMENSION=768

EMBEDDING_ROLLOUT_MODE=provider
EMBEDDING_FILTER_STRICT=false

DOCLING_ENABLED=true
GOOGLE_PARSER_ENABLED=false
PARSER_ROUTING_MODE=docling_google_fallback
LANGEXTRACT_ENABLED=true

REDIS_URL_LOCAL=redis://localhost:6379/0
OLLAMA_BASE_URL_LOCAL=http://localhost:11434
DOCUMENT_INSIGHT_API_BASE_URL_LOCAL=http://localhost:8000

REDIS_URL_DOCKER=redis://redis:6379/0
OLLAMA_BASE_URL_DOCKER=http://ollama:11434
DOCUMENT_INSIGHT_API_BASE_URL_DOCKER=http://api:8000
